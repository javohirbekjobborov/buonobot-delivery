# ── Payme (Paycom) Merchant API ──────────────────────────────
# Merchant kabinet: biznes → "Кассы" → kassa → "Настройки" (Merchant ID),
#   "Инструменты разработчика" (Endpoint & Key).
# Merchant kabinetда Endpoint URL sifatida quyidagini kiriting:  <APP_URL>/payme
PAYME_MERCHANT_ID=
PAYME_KEY=          # production kalit
PAYME_TEST_KEY=     # sandbox (test.paycom.uz) kaliti
# PAYME_CHECKOUT_URL=https://checkout.paycom.uz   # ixtiyoriy
# PAYME_ACCOUNT_FIELD=order_id                    # kabinetdagi rekvizit nomi bilan bir xil

# ── iiko Cloud API ───────────────────────────────────────────
IIKO_API_LOGIN=
IIKO_ORGANIZATION_ID=
IIKO_TERMINAL_GROUP_ID=
IIKO_CRM_ENABLED=false
